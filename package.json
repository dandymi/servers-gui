{
  "name": "servers-gui",
  "version": "1.0.0",
  "description": "GUI interface for managing bash scripts to start/stop applications with on/off indicators",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "build": "tsc && electron-builder",
    "dist": "electron-builder --publish=never",
    "watch": "tsc -w"
  },
  "keywords": [
    "electron",
    "gui",
    "server",
    "management",
    "bash",
    "scripts"
  ],
  "author": {
    "name": "Daniele",
    "email": "daniele@example.com"
  },
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/js-yaml": "^4.0.5",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.daniele.serversgui",
    "productName": "Servers GUI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "preload.js",
      "index.html",
      "style.css",
      "servers.yml",
      "scripts/",
      "node_modules/**/*",
      "package.json"
    ],
    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 240,
          "y": 150
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Daniele <daniele@example.com>"
    },
    "win": {
      "target": "NSIS"
    }
  },
  "homepage": "https://github.com/daniele/servers-gui"
}